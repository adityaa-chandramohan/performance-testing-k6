{
  "id": null,
  "uid": "k6-perf-overview",
  "title": "k6 Performance + API System Metrics",
  "description": "k6 load test metrics (via Prometheus remote-write) combined with API container system metrics (cAdvisor + prom-client)",
  "tags": ["k6", "performance", "api"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-30m", "to": "now" },

  "templating": { "list": [] },
  "annotations": { "list": [] },

  "panels": [

    {
      "id": 1,
      "type": "row",
      "title": "k6 Load Test",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Virtual Users",
      "description": "Current number of active k6 virtual users",
      "gridPos": { "x": 0, "y": 1, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "red", "value": 60 }
            ]
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "k6_vus",
          "legendFormat": "VUs",
          "refId": "A"
        }
      ]
    },

    {
      "id": 3,
      "type": "stat",
      "title": "Request Rate",
      "description": "HTTP requests per second",
      "gridPos": { "x": 4, "y": 1, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          },
          "unit": "reqps"
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(k6_http_reqs_total[1m])",
          "legendFormat": "req/s",
          "refId": "A"
        }
      ]
    },

    {
      "id": 4,
      "type": "stat",
      "title": "Error Rate",
      "description": "Fraction of k6 requests that failed",
      "gridPos": { "x": 8, "y": 1, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.02 },
              { "color": "red", "value": 0.05 }
            ]
          },
          "unit": "percentunit",
          "max": 1
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "k6_http_req_failed",
          "legendFormat": "error rate",
          "refId": "A"
        }
      ]
    },

    {
      "id": 5,
      "type": "stat",
      "title": "p95 Response Time",
      "description": "95th percentile HTTP request duration",
      "gridPos": { "x": 12, "y": 1, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 300 },
              { "color": "red", "value": 500 }
            ]
          },
          "unit": "ms"
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "k6_http_req_duration_p95",
          "legendFormat": "p95",
          "refId": "A"
        }
      ]
    },

    {
      "id": 6,
      "type": "stat",
      "title": "Checks Passed",
      "description": "Fraction of k6 checks that passed",
      "gridPos": { "x": 16, "y": 1, "w": 4, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.95 },
              { "color": "green", "value": 0.99 }
            ]
          },
          "unit": "percentunit",
          "max": 1
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "k6_checks / (k6_checks + k6_checks_fail)",
          "legendFormat": "passed",
          "refId": "A"
        }
      ]
    },

    {
      "id": 7,
      "type": "timeseries",
      "title": "Virtual Users Over Time",
      "gridPos": { "x": 0, "y": 5, "w": 12, "h": 7 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "k6_vus",
          "legendFormat": "Active VUs",
          "refId": "A"
        },
        {
          "datasource": "Prometheus",
          "expr": "k6_vus_max",
          "legendFormat": "Max VUs",
          "refId": "B"
        }
      ]
    },

    {
      "id": 8,
      "type": "timeseries",
      "title": "HTTP Request Rate",
      "gridPos": { "x": 12, "y": 5, "w": 12, "h": 7 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(k6_http_reqs_total[30s])",
          "legendFormat": "requests/sec",
          "refId": "A"
        }
      ]
    },

    {
      "id": 9,
      "type": "timeseries",
      "title": "HTTP Request Duration (k6)",
      "description": "Response time percentiles from k6 measurements",
      "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max", "mean"] },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "k6_http_req_duration_p50",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": "Prometheus",
          "expr": "k6_http_req_duration_p95",
          "legendFormat": "p95 (SLO: <500ms)",
          "refId": "B"
        },
        {
          "datasource": "Prometheus",
          "expr": "k6_http_req_duration_p99",
          "legendFormat": "p99",
          "refId": "C"
        },
        {
          "datasource": "Prometheus",
          "expr": "k6_http_req_duration_max",
          "legendFormat": "max",
          "refId": "D"
        }
      ]
    },

    {
      "id": 10,
      "type": "timeseries",
      "title": "API Request Duration by Route (prom-client)",
      "description": "Server-side latency histograms from the Express API — breakdowns by route",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 8 },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum(rate(api_http_request_duration_seconds_bucket[1m])) by (le, route))",
          "legendFormat": "p95 {{ route }}",
          "refId": "A"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.50, sum(rate(api_http_request_duration_seconds_bucket[1m])) by (le, route))",
          "legendFormat": "p50 {{ route }}",
          "refId": "B"
        }
      ]
    },

    {
      "id": 11,
      "type": "timeseries",
      "title": "API Request Rate by Route & Status (prom-client)",
      "gridPos": { "x": 0, "y": 28, "w": 12, "h": 7 },
      "options": {
        "legend": { "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(api_http_requests_total[30s])) by (route, status_code)",
          "legendFormat": "{{ route }} {{ status_code }}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 12,
      "type": "timeseries",
      "title": "k6 Error Rate",
      "gridPos": { "x": 12, "y": 28, "w": 12, "h": 7 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.02 },
              { "color": "red", "value": 0.05 }
            ]
          },
          "custom": {
            "thresholdsStyle": { "mode": "dashed+area" }
          }
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "k6_http_req_failed",
          "legendFormat": "HTTP error rate",
          "refId": "A"
        },
        {
          "datasource": "Prometheus",
          "expr": "k6_error_rate",
          "legendFormat": "Custom error rate",
          "refId": "B"
        }
      ]
    },

    {
      "id": 20,
      "type": "row",
      "title": "API Container System Metrics (cAdvisor)",
      "gridPos": { "x": 0, "y": 35, "w": 24, "h": 1 },
      "collapsed": false
    },

    {
      "id": 21,
      "type": "timeseries",
      "title": "API Container CPU Usage",
      "description": "CPU cores consumed by the api container",
      "gridPos": { "x": 0, "y": 36, "w": 12, "h": 7 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "color": { "mode": "palette-classic" } }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(container_cpu_usage_seconds_total{name=\"perf_api\"}[30s])",
          "legendFormat": "API CPU %",
          "refId": "A"
        }
      ]
    },

    {
      "id": 22,
      "type": "timeseries",
      "title": "API Container Memory Usage",
      "description": "Resident memory of the api container",
      "gridPos": { "x": 12, "y": 36, "w": 12, "h": 7 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "color": { "mode": "palette-classic" } }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "container_memory_rss{name=\"perf_api\"}",
          "legendFormat": "RSS",
          "refId": "A"
        },
        {
          "datasource": "Prometheus",
          "expr": "container_memory_usage_bytes{name=\"perf_api\"}",
          "legendFormat": "Total usage",
          "refId": "B"
        }
      ]
    },

    {
      "id": 23,
      "type": "timeseries",
      "title": "API Container Network I/O",
      "gridPos": { "x": 0, "y": 43, "w": 12, "h": 7 },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": { "unit": "Bps", "color": { "mode": "palette-classic" } }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(container_network_receive_bytes_total{name=\"perf_api\"}[30s])",
          "legendFormat": "RX bytes/s",
          "refId": "A"
        },
        {
          "datasource": "Prometheus",
          "expr": "rate(container_network_transmit_bytes_total{name=\"perf_api\"}[30s])",
          "legendFormat": "TX bytes/s",
          "refId": "B"
        }
      ]
    },

    {
      "id": 24,
      "type": "timeseries",
      "title": "Node.js Process Metrics (prom-client defaults)",
      "description": "Event loop lag, heap used, open file descriptors",
      "gridPos": { "x": 12, "y": 43, "w": 12, "h": 7 },
      "options": {
        "legend": { "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" } }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "nodejs_heap_size_used_bytes",
          "legendFormat": "Heap used (bytes)",
          "refId": "A"
        },
        {
          "datasource": "Prometheus",
          "expr": "nodejs_eventloop_lag_seconds * 1000",
          "legendFormat": "Event loop lag (ms)",
          "refId": "B"
        },
        {
          "datasource": "Prometheus",
          "expr": "process_open_fds",
          "legendFormat": "Open file descriptors",
          "refId": "C"
        }
      ]
    }

  ]
}
